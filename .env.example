# ─────────────────────────────────────────────────────────────────────────────
# Sentinel – Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose loads this automatically via:
#   env_file:
#     - .env
# ─────────────────────────────────────────────────────────────────────────────

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  PRIVATE REGISTRY CREDENTIALS                                            ║
# ║                                                                          ║
# ║  Fill these in if your containers use ghcr.io, private Docker Hub,       ║
# ║  GitLab registry, or any other private registry.                         ║
# ║                                                                          ║
# ║  Without these, Sentinel will log:                                       ║
# ║    "private registry auth not configured for ghcr.io"                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Option A: Generic credentials (simplest – works for ALL registries) ───────
# For ghcr.io: use your GitHub username + a Personal Access Token (PAT)
#   GitHub → Settings → Developer Settings → Personal Access Tokens → Tokens (classic)
#   Required scope: read:packages
#
REPO_USER=
REPO_PASS=

# ── Option B: Per-registry credentials (use when you have multiple registries)
# Hostname normalization: uppercase, replace . : - with _
#   ghcr.io          → GHCR_IO
#   registry.k8s.io  → REGISTRY_K8S_IO
#   my-reg:5000      → MY_REG_5000
#
# SENTINEL_REGISTRY_USER_GHCR_IO=your_github_username
# SENTINEL_REGISTRY_PASS_GHCR_IO=ghp_yourPersonalAccessToken
#
# SENTINEL_REGISTRY_USER_REGISTRY_1_DOCKER_IO=dockerhub_username
# SENTINEL_REGISTRY_PASS_REGISTRY_1_DOCKER_IO=dockerhub_access_token

# ── Option C: Token-only (single PAT, no username required) ──────────────────
# SENTINEL_REGISTRY_TOKEN_GHCR_IO=ghp_yourPersonalAccessToken

# ── Option D: Mount existing Docker config.json from the host ────────────────
# Set this to the DIRECTORY containing config.json (same as Docker CLI convention)
# Then mount it: volumes: [ /root/.docker:/root/.docker:ro ]
#
DOCKER_CONFIG=
